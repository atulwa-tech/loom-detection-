# Environment Configuration
# Copy this file to .env and update with your actual values

# API Configuration
API_BASE_URL=http://localhost:8080/api
WS_URL=ws://localhost:8080/ws

# Backend Type: 'dummy', 'rest', or 'websocket'
BACKEND_TYPE=dummy

# ESP32 Configuration
ESP32_IP=192.168.1.100
ESP32_PORT=8080

# Feature Flags
ENABLE_WEBSOCKET=false
ENABLE_REAL_API=false
ENABLE_HISTORY=true
ENABLE_ALERTS=true

# Thresholds
TEMP_WARNING_THRESHOLD=50
TEMP_ERROR_THRESHOLD=80

# UI Configuration
AUTO_REFRESH_INTERVAL=1000
THEME_MODE=light

# Debug Mode
DEBUG=false
LOG_API_CALLS=true
